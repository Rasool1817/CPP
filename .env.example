# AWS Credentials (for local development only - NEVER commit .env)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=eu-west-1

# Frontend Configuration (update after first backend deployment)
VITE_API_URL=https://your-api-id.execute-api.eu-west-1.amazonaws.com/prod
VITE_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your_cognito_client_id
VITE_AWS_REGION=eu-west-1

# S3 Frontend Bucket
FRONTEND_BUCKET=warranty-tracker-frontend-prod
